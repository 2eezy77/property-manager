# ─────────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173
# Vite dev proxy reads PORT (or API_PORT) from this file — must match the API process
# Production (Railway): https://www.monterorentals.com
# LAN testing (optional): leave localhost; use npm run dev:lan + open http://<host-ip>:5173 on Mac mini
# DEV_LAN=1
# HOST=0.0.0.0

# ─────────────────────────────────────────────────────────────────────────────
# Database — USE THE SESSION POOLER URL FROM SUPABASE (not the direct URL)
#
# Where to find it:
#   Supabase Dashboard → your project → Settings → Database
#   → Connection string → select "Session pooler" tab
#   → Copy the URI and replace [YOUR-PASSWORD] with your DB password
#
# It looks like this:
#   postgresql://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres
#
# NOT the direct connection (db.xxx.supabase.co) — that one can have DNS issues.
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.YOURPROJECTREF:YOURPASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ─────────────────────────────────────────────────────────────────────────────
# JWT Secrets — generate each one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Run the command TWICE and use different values for each.
# ─────────────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=REPLACE_ME
JWT_REFRESH_SECRET=REPLACE_ME_DIFFERENT_VALUE
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Local dev auto-login (Vite only — skipped in production builds)
# npm run qa:bootstrap -- --apply prints the block below with a known password
# VITE_DEV_LOGIN_EMAIL=owner@example.com
# VITE_DEV_LOGIN_PASSWORD=YOUR_GENERATED_PASSWORD

# Password scripts on shared Supabase DB — blocks tenant resets unless set
# ALLOW_DB_PASSWORD_RESET=1

# ─────────────────────────────────────────────────────────────────────────────
# Encryption key for Plaid access tokens (must be exactly 32 bytes → base64)
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ─────────────────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=REPLACE_ME

# ─────────────────────────────────────────────────────────────────────────────
# Plaid — https://dashboard.plaid.com/developers/keys
# ─────────────────────────────────────────────────────────────────────────────
PLAID_CLIENT_ID=REPLACE_ME
PLAID_SECRET=REPLACE_ME
PLAID_ENV=sandbox
PLAID_REDIRECT_URI=http://localhost:5173/oauth-return

# Webhooks — register https://www.monterorentals.com/webhooks/plaid in Plaid Dashboard.
# Verification uses JWT (Plaid-Verification header), not a shared secret.
PLAID_WEBHOOK_URL=
# PLAID_WEBHOOK_VERIFY_DISABLED=true   # local sandbox only — skip JWT verification

# Signal — ACH return-risk scoring before rent/utility debits (requires Dashboard ruleset)
# Enable Signal product on your Plaid account first (Dashboard → Signal, or contact Plaid).
# Create a Production ruleset at Dashboard → Signal → Rules; copy its key below.
PLAID_SIGNAL_ENABLED=false
PLAID_SIGNAL_RULESET_KEY=
# After enabling, run: npm run plaid:signal:prepare
# Comma-separated ruleset results that block charges (default REVIEW,REROUTE)
# PLAID_SIGNAL_BLOCK_RESULTS=REVIEW,REROUTE

# Balance — optional real-time balance check before ACH debits
PLAID_BALANCE_CHECK_ENABLED=false
# Block charge when balance is insufficient (default true; set false to log only)
# PLAID_BALANCE_BLOCK=true

# ─────────────────────────────────────────────────────────────────────────────
# Stripe — https://dashboard.stripe.com/apikeys
# STRIPE_WEBHOOK_SECRET — live: Dashboard → Developers → Webhooks → signing secret
#   Local dev: npm run stripe:listen (whsec_... printed on startup)
#   Forward URL: http://localhost:8080/webhooks/stripe  (uses PORT from .env)
# Ops: npm run payments:health · npm run stripe:webhook:sync · npm run stripe:connect:status
# Live webhook URL: https://www.monterorentals.com/webhooks/stripe
# Events: payment_intent.*, charge.dispute.created, account.updated (see stripe.service.js)
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Daily rent invoices (1st of month) + late fees after grace period
# RENT_BILLING_ENABLED=false disables the in-process scheduler
RENT_BILLING_ENABLED=true
RENT_BILLING_HOUR=8

# ─────────────────────────────────────────────────────────────────────────────
# Rocket Lawyer — https://developer.rocketlawyer.com
# Sandbox: https://api-sandbox.rocketlawyer.com
# Production: https://api.rocketlawyer.com
#
# 1. Create app at developer.rocketlawyer.com (name ends in -sandbox for testing)
# 2. Request Docs + Sign API permissions; wait for app approval
# 3. Copy App Key + Secret below (Postman calls these api_key / api_secret)
# 4. Set RL_WEBHOOK_URL to your public app origin (enables Events API polling)
# 5. Run npm run rocketlawyer:probe → save RL_EVENTS_SUBSCRIPTION_ID
# 6. Set RL_LEASE_TEMPLATE_ID from GET /rocketdoc/v2/templates (VA lease)
# ─────────────────────────────────────────────────────────────────────────────
RL_API_KEY=REPLACE_ME
RL_API_SECRET=REPLACE_ME
# Aliases also accepted: RL_CLIENT_ID / RL_CLIENT_SECRET
RL_BASE_URL=https://api-sandbox.rocketlawyer.com
RL_AUTH_PATH=/partners/v1/auth/accesstoken
RL_SERVICE_TOKEN_PATH=/partners/v1/auth/servicetoken
RL_BINDER_PREFIX=/document-manager/v1/binders
RL_ROCKETDOC_PREFIX=/rocketdoc/v2
RL_EVENTS_PREFIX=/events/v1
RL_EVENTS_SUBSCRIPTION_ID=
RL_WEBHOOK_SECRET=
RL_WEBHOOK_URL=
RL_POLL_EVENTS_MS=60000
RL_LEASE_TEMPLATE_ID=REPLACE_ME
# Service token purposes (from partner-auth OpenAPI)
RL_SERVICE_TOKEN_PURPOSE_BINDER=api.rocketlawyer.com/binder-party-access
RL_SERVICE_TOKEN_PURPOSE_ROCKETDOC=api.rocketlawyer.com/rocketdoc
# RL_UPID=  # party UPID for binder embedded sign service tokens

# ─────────────────────────────────────────────────────────────────────────────
# Optional AI communication agent (tenant message triage / draft replies)
# Requires an Anthropic API key: https://console.anthropic.com
# ─────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
AI_AGENT_MODEL=claude-haiku-4-5-20251001

# ─────────────────────────────────────────────────────────────────────────────
# Utility bills — import from Gmail (Dominion + HRSD e-bills)
# 1. Create OAuth credentials at https://console.cloud.google.com/apis/credentials
#    Application type: Web application
#    Authorized redirect URI: http://localhost:8080/api/utilities/gmail/callback
# 2. Enable Gmail API for the project
# 3. Connect in Manager → Utilities → Connect Gmail (stores refresh token in DB)
# Optional CLI: npm run gmail:auth  (redirect http://localhost:8099/callback)
# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8080/api/utilities/gmail/callback
# Production must use www (apex monterorentals.com does not reach Railway):
# GOOGLE_REDIRECT_URI=https://www.monterorentals.com/api/utilities/gmail/callback
# GMAIL_REFRESH_TOKEN=
# GMAIL_ADDRESS=

# Property account numbers — set via PATCH /api/properties/:id to match e-bill emails:
# dominion_account_number, norfolk_utilities_account_number


# ─────────────────────────────────────────────────────────────────────────────
# Optional: override the admin email created by db:seed
# ─────────────────────────────────────────────────────────────────────────────
# SEED_ADMIN_EMAIL=you@yourdomain.com

# ─────────────────────────────────────────────────────────────────────────────
# Outbound email (payment reminders, payment received/failed)
# Sends via org Gmail OAuth (Manager → Utilities → Connect Gmail).
# Reconnect Gmail after upgrading to include send scope.
# Optional Resend fallback: RESEND_API_KEY + EMAIL_FROM
# EMAIL_DEV_OVERRIDE=you@gmail.com  — route all mail here in dev
# EMAIL_ENABLED=false               — log only, do not send
# ─────────────────────────────────────────────────────────────────────────────
# EMAIL_DEV_OVERRIDE=
# RESEND_API_KEY=
# EMAIL_FROM="743 A Ave <onboarding@resend.dev>"
